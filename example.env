# Copy to .env and fill in real values. Never commit .env.
#
# Proxmox API (used by packer proxmox-iso builders and deploy scripts)
PROXMOX_URL=https://192.168.60.1:8006/api2/json
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=change-me
PROXMOX_HOST=192.168.60.1

# Wazuh manager API (verify scripts, optional agent checks)
WAZUH_MANAGER_HOST=192.168.61.10
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=change-me

# Domain controller deploy (scripts/proxmox/deploy-dc.sh)
AD_DOMAIN=heliumsupply.local
AD_SAFEMODE_PASSWORD=change-me
AD_ADMIN_PASSWORD=change-me

# Challenge flags at build time (override per event)
SECRETCON_USER_FLAG=event-example-user-flag
SECRETCON_ROOT_FLAG=event-example-root-flag

# Three-box chain: shared local Administrator password (CysVuln + EWS misconfig)
SECRETCON_SHARED_LOCAL_ADMIN_PASSWORD=PizzaMan123!

# ASREP DC campaign flags (integrated chain)
SECRETCON_DC_USER_FLAG=event-example-dc-user-flag
SECRETCON_DC_ROOT_FLAG=event-example-dc-root-flag
SECRETCON_ASREP_ENITE_DA=1

# CysVuln artifact overrides (optional; defaults in fetch-cysvuln-artifacts.sh)
# CYSVULN_INSTALLER_HASH=60ea3256cd272797675e2ec6ea8e02d8ad51209f1cbf9083bc909284b5331d79
# CYSVULN_INSTALLER_URL=
