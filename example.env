# Copy to .env and fill in real values. Never commit .env.

# Proxmox API (packer proxmox-iso builders, scripts/proxmox/*)
PROXMOX_URL=https://192.168.60.1:8006/api2/json
PROXMOX_USERNAME=root@pam
PROXMOX_PASSWORD=change-me
PROXMOX_HOST=192.168.60.1
# Ansible community.proxmox (playbooks/proxmox/*) uses PROXMOX_HOST / PROXMOX_PASSWORD

# Wazuh manager API (verify scripts, baseline snapshots, probe-ews)
WAZUH_MANAGER_HOST=192.168.61.10
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=change-me

# OPS webhook for challenge exploit-path alerts (custom-ops-queue integration)
WAZUH_OPS_WEBHOOK_URL=
WAZUH_OPS_AUTO_RESET=0

# CTF baseline reset (scripts/host/ctf-baseline-reset.sh) — default off until event window
CTF_SCHEDULED_RESET_ENABLED=0
CTF_BASELINE_SNAPSHOT_TAG=ctf-baseline

# EWS failover (scripts/host/challenge-failover.sh) — operator-first; auto via orchestrator
EWS_FAILOVER_AUTO=0
EWS_BACKEND_PRIMARY=192.168.61.20:5985
EWS_BACKEND_STANDBY=192.168.61.21:5985
EWS_STANDBY_VMID=120

# OPNsense (scripts/proxmox/opnsense-*.sh, provisioning/opnsense/scripts/export-config.sh)
OPNSENSE_HOST=192.168.61.253
OPNSENSE_API_KEY=change-me
OPNSENSE_API_SECRET=change-me
OPNSENSE_SSH_PASSWORD=change-me
OPNSENSE_SSH_USER=root
OPNSENSE_VERIFY_TLS=0
OPNSENSE_MIRROR_IFACE=vtnet2
# OPNSENSE_SSH_KEY=/path/to/opnsense_ed25519

# Domain controller deploy (scripts/proxmox/deploy-dc.sh, ASREP bootstrap)
AD_DOMAIN=heliumsupply.local
AD_SAFEMODE_PASSWORD=change-me
AD_ADMIN_PASSWORD=change-me
AD_NETBIOS=SECRETCON

# Challenge flags at build time (override per event)
SECRETCON_USER_FLAG=event-example-user-flag
SECRETCON_ROOT_FLAG=event-example-root-flag

# Three-box chain: shared local Administrator password (CysVuln + EWS).
# Proxmox VMID 118 baseline may still answer WinRM as `packer` until
# `ansible-playbook cysvuln.yml` campaign_shared_admin runs with this set.
SECRETCON_SHARED_LOCAL_ADMIN_PASSWORD=PizzaMan123!

# ASREP DC campaign flags (integrated chain)
SECRETCON_DC_USER_FLAG=event-example-dc-user-flag
SECRETCON_DC_ROOT_FLAG=event-example-dc-root-flag
SECRETCON_ASREP_ENITE_DA=1
SECRETCON_ASREP_USER=enite
SECRETCON_ASREP_PASSWORD=stud87
SECRETCON_ASREP_FLAG=event-example-asrep-flag

# CysVuln artifact overrides (optional; fetch-cysvuln-artifacts.sh)
# CYSVULN_INSTALLER_HASH=60ea3256cd272797675e2ec6ea8e02d8ad51209f1cbf9083bc909284b5331d79
# CYSVULN_INSTALLER_URL=

# EWS / VNC adversary emulation (campaign vmbr1)
EWS_HOST=192.168.61.20
EWS_PROD_HOST=192.168.60.109
# Pin guest IPv4 at converge (stops DHCP drift on vmbr1); leave empty to skip
EWS_STATIC_IP=192.168.61.20
EWS_STATIC_GATEWAY=192.168.61.1
EWS_STATIC_DNS=192.168.61.52,192.168.61.10
EWS_TARGET=192.168.61.20
EWS_VM_ID=109
EWS_FINAL_BRIDGE=vmbr1
# Opt-in lab activation (ansible windows_activation role); 0 = off
EWS_WINDOWS_ACTIVATION=0
# EWS hypervisor sizing (Ansible ews-hypervisor.yml; defaults match Packer)
EWS_MEMORY_MB=8192
EWS_CPU_CORES=4
EWS_AGENT_ENABLED=1
PATRICK_PW=Changeme123!
VNC_PW=FELDTECH_VNC
ADMIN_PW=change-me
VNC_PORT=5900
WINRM_PORT=5985
WG_INTERFACE=wg-ctf

# Arkime / capture (scripts/proxmox/sync-arkime-pcap.sh, vnc validators)
ARKIME_HOST=192.168.61.11
CAPTURE_IFACE=wg-ctf
ARKIME_ADMIN_USER=admin
ARKIME_ADMIN_PASSWORD=change-me
ARKIME_VIEWER_PORT=8005
ARKIME_OS_PORT=9201

# Joe-tier / MSF AIE validation (scripts/validate/run_msfvenom_aie.py)
JOE_USER=User_Joe
JOE_PW=change-me
# MSF_LHOST MSF_LPORT MSF_PAYLOAD MSF_ENCODER — see run_msfvenom_aie.py

# Wazuh dataset replay (scripts/lib/wazuh_replay.py)
# REPLAY_HOST REPLAY_PORT REPLAY_DATASET — set per replay run

# Ansible live EWS (ansible/inventory/host_vars/ews-prod.yml)
ANSIBLE_ADMIN_PASSWORD=packer
