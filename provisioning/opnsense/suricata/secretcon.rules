# SecretCon custom Suricata signatures for the OPNsense MIRROR interface.
#
# Loaded via Services -> Intrusion Detection -> Administration -> Schedule
# /usr/local/etc/suricata/rules/secretcon.rules under "Custom rules"
# OR by writing this file to the OPNsense host and reloading Suricata
# (scripts/proxmox/opnsense-apply-config.sh handles both paths).
#
# These signatures are TUNED FOR THE SECRETCON LAB and intentionally
# under-throttled compared to production ET rules so the EWS analyst
# challenge sees a guaranteed hit during a controlled wordlist run.
#
# Coverage:
#   2400001 -- VNC RFB connection burst (>=10 to_server / 60s same src)
#              Catches the brute-force probe pattern regardless of
#              whether the server engages or not.
#   2400002 -- VNC RFB SecurityResult=Failed reply burst (>=5 / 60s same dst)
#              Server-side; only fires when the brute force is actually
#              being answered with failures. Higher fidelity than 2400001.
#   2400003 -- VNC RFB SecurityResult=OK reply
#              Server-side; lets Wazuh correlate failed auths followed by
#              a successful login from the same source.
#
# Detection table is in docs/runbooks/opnsense-vnc-brute-analyst-challenge.md
# Bridged to Wazuh rules 100810 / 100811 / 100812 / 100813 / 100816
# via infrastructure/wazuh-docker/config/wazuh_cluster/local_rules.xml.

# ---- SID 2400001 -------------------------------------------------------
# VNC RFB connection burst (brute-force probe pattern).
alert tcp $EXTERNAL_NET any -> $HOME_NET 5900 \
    ( msg:"SECRETCON VNC RFB connection burst"; \
      flow:to_server; \
      threshold: type both, track by_src, count 10, seconds 60; \
      classtype:attempted-recon; \
      reference:url,docs.suricata.io/en/latest/rules/thresholding.html; \
      metadata:secretcon vnc-brute, mitre_attack T1110.001; \
      sid:2400001; rev:1; )

# ---- SID 2400002 -------------------------------------------------------
# VNC RFB SecurityResult=Failed reply burst.
#
# Per RFC 6143 sec 7.1.2 (RFB Security): after the client sends its
# 16-byte DES response, the server replies with a 4-byte SecurityResult
# integer. 0 = OK, 1 = Failed (RFB 3.7+ may follow with a reason string).
# We anchor on the literal `00 00 00 01` Failed value with depth:4 so we
# only match the first response byte block in the server's reply, not
# arbitrary 4-byte sequences elsewhere in the stream.
alert tcp $HOME_NET 5900 -> $EXTERNAL_NET any \
    ( msg:"SECRETCON VNC RFB SecurityResult=Failed"; \
      flow:from_server,established; \
      content:"|00 00 00 01|"; depth:4; \
      threshold: type threshold, track by_dst, count 5, seconds 60; \
      classtype:attempted-user; \
      metadata:secretcon vnc-brute-failures, mitre_attack T1110.001; \
      sid:2400002; rev:1; )

# ---- SID 2400003 -------------------------------------------------------
# VNC RFB SecurityResult=OK reply.
#
# The success record uses the same 4-byte SecurityResult integer as the
# failure rule above. This does not reveal the password; it marks the
# moment a brute-force sequence turned into an authenticated VNC session.
alert tcp $HOME_NET 5900 -> $EXTERNAL_NET any \
    ( msg:"SECRETCON VNC RFB SecurityResult=OK"; \
      flow:from_server,established; \
      content:"|00 00 00 00|"; depth:4; \
      classtype:successful-user; \
      metadata:secretcon vnc-auth-success, mitre_attack T1110.001; \
      sid:2400003; rev:1; )
